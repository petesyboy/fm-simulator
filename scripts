import csv
import json
import os
import glob

data_dir = r'D:\projects\fm-simulator\public datasheets'
json_path = r'D:\projects\fm-simulator\src\constants\skus.json'

sku_dict = {}

csv_files = glob.glob(os.path.join(data_dir, '*.csv'))

for csv_path in csv_files:
    try:
        with open(csv_path, 'r', encoding='utf-8-sig') as f:
            first_line = f.readline()
            if not first_line.startswith('EFFECTIVE DATE'):
                f.seek(0)
            
            reader = csv.DictReader(f)
            for row in reader:
                sku = row.get('SKU', '')
                if sku:
                    sku = sku.strip()
                desc = row.get('Detailed Description', '')
                if desc:
                    desc = desc.strip()
                    
                if sku and desc:
                    sku_dict[sku] = desc
    except Exception as e:
        print(f'Error reading {csv_path}: {e}')

try:
    with open(json_path, 'w', encoding='utf-8') as f:
        json.dump(sku_dict, f, indent=2)
    print(f'Successfully extracted {len(sku_dict)} SKUs from {len(csv_files)} CSV files to {json_path}')
except Exception as e:
    print(f'Error writing JSON: {e}')
